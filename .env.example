# ==============================================
# Hedera Social Platform — Environment Variables
# ==============================================
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.

# ── General ──
NODE_ENV=development                              # development | production | test
LOG_LEVEL=debug                                   # debug | info | warn | error

# ── Hedera Network ──
HEDERA_NETWORK=testnet                            # testnet | mainnet
HEDERA_OPERATOR_ID=0.0.XXXXX                      # Your testnet operator account
HEDERA_OPERATOR_KEY=302e020100...                  # Your testnet operator private key (DER hex)
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# ── Hedera Topic & Token IDs (created during T08 Testnet Setup) ──
HEDERA_DID_TOKEN_ID=                              # HTS token for DID NFTs (minted in T08)
HEDERA_KYC_ATTESTATION_TOPIC=                     # HCS topic for KYC attestations
HEDERA_SOCIAL_GRAPH_TOPIC=                        # HCS topic for follow/unfollow events
HEDERA_ANNOUNCEMENTS_TOPIC=                       # HCS topic for platform announcements
HTS_TOKEN_ID=                                     # HTS token for payment transfers
NOTIFICATION_TOPIC_ID=                            # HCS topic for notifications

# ── PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=hedera_social
DB_PASSWORD=CHANGE_ME
DB_NAME=hedera_social
DB_SSL=false
DB_SYNCHRONIZE=false                              # true only in development
DB_LOGGING=false                                  # true to log SQL queries
# Aliases (some task files use these alternative names):
# DATABASE_URL — composite form: postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
# DB_DATABASE — alias for DB_NAME
# PORT — alias for API_PORT

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL — composite form: redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ── Encryption ──
ENCRYPTION_MASTER_KEY=                            # 256-bit hex key for AES-256-GCM master encryption

# ── JWT Auth ──
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=CHANGE_ME_TO_DIFFERENT_RANDOM_STRING
JWT_REFRESH_EXPIRY=30d
# Aliases: JWT_EXPIRATION = JWT_EXPIRY, JWT_REFRESH_EXPIRATION = JWT_REFRESH_EXPIRY

# ── API ──
API_PORT=3001
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_ENABLE_CHAT=true                      # Feature flag: enable chat module
NEXT_PUBLIC_ENABLE_KYC=true                       # Feature flag: enable KYC flow
NEXT_PUBLIC_ENABLE_PAYMENTS=true                  # Feature flag: enable payment features

# ── Socket.io ──
WS_PORT=3001
WS_CORS_ORIGINS=http://localhost:3000

# ── Tamam MPC Custody ──
TAMAM_CUSTODY_API_URL=https://tamam-backend-staging-776426377628.us-central1.run.app
TAMAM_CUSTODY_API_KEY=
TAMAM_CUSTODY_MOCK=false                          # true to use mock mode in development

# ── Tamam Payment Rails ──
TAMAM_RAILS_API_URL=                              # Payment rails endpoint (if external)
TAMAM_RAILS_API_KEY=
TAMAM_RAILS_MOCK=false                            # true to use mock mode in development

# ── Mirsad AI KYC/AML ──
MIRSAD_KYC_API_URL=https://dashboard-api.olara.io
MIRSAD_KYC_CALLBACK_URL=https://your-domain.com/kyc/callback
MIRSAD_KYC_ENABLED=true                           # false to skip KYC in development

# ── Pinata IPFS (for NFT metadata storage) ──
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY_URL=                               # e.g., https://gateway.pinata.cloud/ipfs/
